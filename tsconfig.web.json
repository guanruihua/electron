{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "node_modules/**/*.d.ts",
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [ "./src/renderer/src/*" ],
    }
  }
}
